# AMADEUS_CLIENT_ID: Required for Amadeus API calls.
# AMADEUS_CLIENT_SECRET: Required for Amadeus API calls.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY_2="MY_SECOND_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DUFFEL_ACCESS_TOKEN: Your Duffel API access token.
# Get one at https://duffel.com/
DUFFEL_ACCESS_TOKEN=

# DATABASE_URL: Your PostgreSQL connection string (legacy Prisma).
DATABASE_URL=

# ── Backend (Node.js/Express on port 5000) ──────────────────────────────
# SQL Server connection for the backend
DB_SERVER=DESKTOP-QOH5V7E\SQLEXPRESS
DB_PORT=1433
DB_NAME=TravelEliteDB
DB_USER=LSM_SE
DB_PASSWORD=5181
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Frontend URL for CORS
CORS_ORIGIN=http://localhost:3000

# ── Frontend (Next.js) ──────────────────────────────────────────────────
# URL where the Node.js backend is running
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
